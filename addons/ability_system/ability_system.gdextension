windows.debug.x86_64 = "res://addons/ability_system/bin/ability_system.windows.editor.x86_64.dll"
windows.release.x86_64 = "res://addons/ability_system/bin/ability_system.windows.template_release.x86_64.dll"

linux.debug.x86_64 = "res://addons/ability_system/bin/libability_system.linux.editor.x86_64.so"
linux.release.x86_64 = "res://addons/ability_system/bin/libability_system.linux.template_release.x86_64.so"
linux.debug.x86_32 = "res://addons/ability_system/bin/libability_system.linux.editor.x86_32.so"
linux.release.x86_32 = "res://addons/ability_system/bin/libability_system.linux.template_release.x86_32.so"
linux.debug.arm64 = "res://addons/ability_system/bin/libability_system.linux.editor.arm64.so"
linux.release.arm64 = "res://addons/ability_system/bin/libability_system.linux.template_release.arm64.so"
linux.debug.arm32 = "res://addons/ability_system/bin/libability_system.linux.editor.arm32.so"
linux.release.arm32 = "res://addons/ability_system/bin/libability_system.linux.template_release.arm32.so"

android.debug.arm64 = "res://addons/ability_system/bin/libability_system.android.editor.arm64.so"
android.release.arm64 = "res://addons/ability_system/bin/libability_system.android.template_release.arm64.so"
android.debug.arm32 = "res://addons/ability_system/bin/libability_system.android.editor.arm32.so"
android.release.arm32 = "res://addons/ability_system/bin/libability_system.android.template_release.arm32.so"
android.debug.x86_64 = "res://addons/ability_system/bin/libability_system.android.editor.x86_64.so"
android.release.x86_64 = "res://addons/ability_system/bin/libability_system.android.template_release.x86_64.so"
