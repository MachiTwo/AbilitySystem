[configuration]

entry_symbol = "as_library_init"
compatibility_minimum = "4.2"

[libraries]

macos.debug = "res://addons/ability_system/bin/libability_system.macos.editor.dylib"
macos.release = "res://addons/ability_system/bin/libability_system.macos.template_release.dylib"

windows.debug.x86_32 = "res://addons/ability_system/bin/ability_system.windows.editor.x86_32.dll"
