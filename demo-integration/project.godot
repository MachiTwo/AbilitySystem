; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the parameters that go here are not all obvious.
;
; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=5

[ability_system]

common/name_tags=PackedStringArray("AttackPower", "Health", "Invulnerability", "Mana", "MoveSpeed", "Stamina", "ability.skill.attack", "ability.skill.charge", "ability.skill.fireball", "ability.skill.heal", "ability.skill.idle", "ability.skill.projectile", "ability.skill.sprint", "ability.skill.summon", "ability.skill.walk", "attribute.attack_power", "attribute.health", "attribute.mana", "attribute.move_speed", "attribute.stamina", "cooldown.fireball", "cooldown.sprint", "cue.anim.attack", "cue.anim.charge", "cue.anim.death", "cue.anim.hurt", "cue.anim.idle", "cue.anim.summon", "cue.anim.throw", "cue.anim.walk", "cue.snd.walk", "effect.attack_buff", "effect.burn", "effect.damage", "effect.haste", "effect.heal", "effect.invulnerability", "effect.poison", "state.attack_buffed", "state.hastened", "state.poisoned", "state.stunned")
common/conditional_tags=PackedStringArray("cooldown.attack", "cooldown.charge", "cooldown.heal", "cooldown.projectile", "cooldown.summon", "state.attacking", "state.burning", "state.charging", "state.critical_health", "state.dead", "state.full_health", "state.hurt", "state.idle", "state.immune", "state.is_moving", "state.low_health", "state.summoning", "state.throwing", "state.walk")

[application]

config/name="LimboAI Demo"
run/main_scene="res://scenes/showcase.tscn"
config/features=PackedStringArray("4.6", "Forward Plus")
config/icon="res://assets/icon.svg"

[display]

window/size/viewport_width=1920
window/size/viewport_height=1080
window/size/mode=3
window/size/window_width_override=1280
window/size/window_height_override=720
window/stretch/mode="canvas_items"

[layer_names]

2d_physics/layer_1="Obstacle"
2d_physics/layer_2="Agent"
2d_physics/layer_3="BoxPlayer"
2d_physics/layer_4="BoxEnemy"

[limbo_ai]

behavior_tree/favorite_tasks=PackedStringArray("BTSequence", "BTSelector", "BTComment")
behavior_tree/user_task_dir_1="res://ai/tasks"
