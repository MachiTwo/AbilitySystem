; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the parameters that go here are not all obvious.
;
; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=5

[ability_system]

common/name_tags=PackedStringArray("Ability.Dash", "Ability.Heal", "Ability.Jump", "Ability.Mega", "Ability.Melee", "Ability.MultiEffect", "Ability.Required", "Ability.Talk", "Ability.Test", "Ability.Timed", "Ability.Walk", "Attack", "Cue.Animation.Attack", "Cue.Audio.Explosion", "Cue.Jump", "Cue.VFX.Explosion", "Cue.Walk", "Effect.Poison", "Effect.Test", "HealEffect", "Health", "IndependentBuff", "JumpEffect", "Mana", "MeleeDamage", "Poison", "Stamina", "WalkEffect", "ability.attack", "ability.counter", "ability.heavy_strike", "ability.idle", "ability.reaction", "ability.skill.attack", "attack_speed", "cue.animation.attack", "cue.animation.death", "cue.animation.hurt", "cue.animation.idle", "cue.animation.walk", "cue.impact", "cue.visual", "effect.damage", "effect.fire", "effect.payload", "move_speed", "state.burn", "test.cue", "test.damage", "test.effect", "test.level_check", "test.poison")
common/conditional_tags=PackedStringArray("Ability.Fireball", "Element.Fire", "State.Active", "State.Alive", "State.Burning", "State.Dashing", "State.Dead", "State.Dead.Bleeding", "State.Ethereal", "State.Grounded", "State.Immune", "State.InCombat", "State.Jumping", "State.Poisoned", "State.Stunned", "State.Talking", "State.Walking", "State.Wet", "ability.skill.idle", "ability.skill.walk", "action.attacking", "action.jumping", "buff.earth", "buff.fire", "buff.water", "character.state.dead", "character.state.hurt", "cooldown.attack", "state.attacked", "state.attacking", "state.blocking", "state.burning", "state.dead", "state.immune", "state.rooted", "state.silenced", "state.stunned", "state.triggered")

[animation]

compatibility/default_parent_skeleton_in_mesh_instance_3d=true

[application]

config/name="AbilitySystem Demo"
run/main_scene="res://levels/sala_teste.tscn"
config/features=PackedStringArray("4.6", "Forward Plus")
config/icon="res://icon.svg"

[display]

window/size/viewport_width=1080
window/size/viewport_height=720

[editor_plugins]

enabled=PackedStringArray("res://addons/ability_system/plugin.cfg")

